{
  "name": "@0xtiby/spawner",
  "version": "0.0.0-development",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xtiby/spawner.git"
  },
  "bugs": {
    "url": "https://github.com/0xtiby/spawner/issues"
  },
  "homepage": "https://github.com/0xtiby/spawner#readme",
  "author": "0xtiby",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "vitest run --config vitest.e2e.config.ts",
    "bootstrap": "bash scripts/bootstrap.sh",
    "setup:branch-protection": "bash scripts/setup-branch-protection.sh"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "semantic-release": "^25.0.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
